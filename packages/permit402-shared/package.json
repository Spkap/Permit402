{
  "name": "@permit402/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./block-reason": {
      "types": "./dist/block-reason.d.ts",
      "default": "./dist/block-reason.js"
    },
    "./category": {
      "types": "./dist/category.d.ts",
      "default": "./dist/category.js"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "default": "./dist/policy.js"
    },
    "./solscan": {
      "types": "./dist/solscan.d.ts",
      "default": "./dist/solscan.js"
    },
    "./x402": {
      "types": "./dist/x402.d.ts",
      "default": "./dist/x402.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@solana/web3.js": "1.95.3"
  },
  "devDependencies": {
    "vitest": "latest"
  }
}
